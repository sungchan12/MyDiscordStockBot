<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} %-5level %logger{0} -- %msg%n</pattern>
        </encoder>
    </appender>

    <!-- JDA(디스코드)와 ktor 는 시끄러우므로 경고 이상만 -->
    <logger name="net.dv8tion.jda" level="WARN"/>
    <logger name="io.ktor" level="WARN"/>

    <!-- 우리 봇 로그는 INFO 유지 -->
    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>